{
  "mainBar": {
    "layer": "top",
    "position": "top",
    "modules-left": ["niri/workspaces", "niri/window"],
    "modules-right": ["clock", "tray"],

    "niri/workspaces": {
      "format": "{name}",
      "all-outputs": true
    },
    "niri/window": {
      "format": "{title}",
      "max-length": 50
    }
  }
}
